{
    "version": 2,
    "builds": [
        {
            "src": "api/*.js",
            "use": "@vercel/node"
        },
        {
            "src": "public/index.html",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/bulk-generate",
            "dest": "/api/bulk-generate.js"
        },
        {
            "src": "/api/discover",
            "dest": "/api/discover.js"
        },
        {
            "src": "/api/autopilot",
            "dest": "/api/autopilot.js"
        },
        {
            "src": "/api/generate",
            "dest": "/api/generate.js"
        },
        {
            "src": "/(.*)",
            "dest": "/public/index.html"
        }
    ]
}