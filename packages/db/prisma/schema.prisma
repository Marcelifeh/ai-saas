generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String            @id @default(cuid())
  name          String?
  email         String?           @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String            @default("user")
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  accounts      Account[]
  sessions      Session[]
  subscriptions Subscription[]
  workspaces    WorkspaceMember[]
  merchOutcomeFeedback MerchOutcomeFeedback[]
}

model Workspace {
  id        String            @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime          @default(now())
  projects  Project[]
  members   WorkspaceMember[]
}

model WorkspaceMember {
  id          String    @id @default(cuid())
  userId      String
  workspaceId String
  role        String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Project {
  id          String    @id @default(cuid())
  name        String
  workspaceId String
  createdAt   DateTime  @default(now())
  niches      Niche[]
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model Niche {
  id               String  @id @default(cuid())
  name             String
  score            Float
  trendScore       Float
  competitionScore Float
  projectId        String
  project          Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Subscription {
  id               String    @id @default(cuid())
  userId           String
  stripeCustomerId String?
  stripeSubId      String?
  plan             String    @default("free")
  status           String    @default("active")
  currentPeriodEnd DateTime?
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model UsageMetric {
  id        String   @id @default(cuid())
  userId    String
  type      String
  value     Int
  createdAt DateTime @default(now())
}

model AutopilotJob {
  id          String   @id @default(cuid())
  status      String   @default("pending")
  workspaceId String
  createdAt   DateTime @default(now())
}

model SignalSnapshot {
  id         String   @id @default(cuid())
  source     String
  snapshotKey String
  data       Json
  fetchedAt  DateTime
  expiresAt  DateTime
  confidence Float
  status     String   @default("live")
  transport  String   @default("live")
  details    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([source, snapshotKey])
  @@index([source, expiresAt])
}

model SignalSourceHealth {
  id            String   @id @default(cuid())
  source        String   @unique
  status        String   @default("healthy")
  failureCount  Int      @default(0)
  lastSuccess   DateTime?
  lastFailure   DateTime?
  cooldownUntil DateTime?
  lastError     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model MerchOutcomeFeedback {
  id           String   @id @default(cuid())
  userId       String
  niche        String
  nicheKey     String
  platform     String
  slogan       String
  sloganKey    String
  pattern      String?
  tags         String[] @default([])
  audience     String?
  style        String?
  productTitle String?
  impressions  Int      @default(0)
  clicks       Int      @default(0)
  orders       Int      @default(0)
  favorites    Int      @default(0)
  revenue      Float    @default(0)
  refunds      Int      @default(0)
  observedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, observedAt])
  @@index([userId, platform, sloganKey, observedAt])
  @@index([userId, platform, nicheKey, observedAt])
  @@index([userId, platform, pattern, observedAt])
}

model SloganPattern {
  id          String   @id @default(cuid())
  niche       String
  pattern     String
  score       Float    @default(1)
  uses        Int      @default(0)
  impressions Int      @default(0)
  clicks      Int      @default(0)
  sales       Int      @default(0)
  ctr         Float    @default(0)
  conversion  Float    @default(0)
  lastSlogan  String?
  nicheHints  String[] @default([])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([niche, pattern])
  @@index([niche, score])
  @@index([score, uses])
  @@index([niche, ctr])
  @@index([niche, conversion])
}

model MarketSignal {
  id         String   @id @default(cuid())
  niche      String
  text       String
  source     String
  nicheKey   String?
  sloganKey  String?
  tagKey     String?
  score      Float    @default(50)
  confidence Float    @default(0.5)
  payload    Json?
  observedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([source, observedAt])
  @@index([niche, observedAt])
  @@index([nicheKey, observedAt])
  @@index([sloganKey, observedAt])
  @@index([tagKey, observedAt])
}

model ListingQueue {
  id           String   @id @default(cuid())
  niche        String
  slogan       String
  title        String
  bullets      String[] @default([])
  tags         String[] @default([])
  mockupPrompt String
  adHooks      String[] @default([])

  status       String   @default("PENDING")
  platform     String   @default("etsy")
  priorityScore Float?  

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ListingPerformance {
  id          String   @id @default(cuid())
  listingId   String
  impressions Int      @default(0)
  clicks      Int      @default(0)
  ctr         Float    @default(0)
  conversions Int      @default(0)
  revenue     Float    @default(0)
  observedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([listingId, observedAt])
}
